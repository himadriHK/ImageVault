<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ImageVault.ViewModels"
             xmlns:models="clr-namespace:ImageVault.Models"
             xmlns:local="clr-namespace:ImageVault"
             x:Class="ImageVault.MainPage"
             x:DataType="vm:MainViewModel"
             Title="ImageVault">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:InvertBoolConverter x:Key="InvertBool" />
            <local:IsZeroConverter x:Key="IsZero" />
            <local:NotIsZeroConverter x:Key="NotIsZero" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <VerticalStackLayout Grid.Row="0" Padding="12,8" Spacing="4"
                             IsVisible="{Binding IsModelLoading}">
            <Label Text="{Binding StatusMessage}"
                   HorizontalOptions="Center"
                   FontSize="13" />
            <ProgressBar Progress="{Binding ModelLoadingProgress}"
                         ProgressColor="{StaticResource Primary}" />
        </VerticalStackLayout>

        <Grid Grid.Row="0" Padding="12,8" ColumnDefinitions="*,Auto,Auto"
              IsVisible="{Binding IsModelLoading, Converter={StaticResource InvertBool}}">
            <Label Text="ImageVault"
                   FontSize="20"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />

            <Button Grid.Column="1"
                    Text="+ Gallery"
                    Command="{Binding PickImagesCommand}"
                    Margin="4,0" />

            <Button Grid.Column="2"
                    Text="&#x1F5D1;"
                    Command="{Binding ClearDatabaseCommand}"
                    Margin="4,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                    BackgroundColor="{StaticResource Danger}" />
        </Grid>

        <Grid Grid.Row="1" Padding="12,4" ColumnDefinitions="*,Auto"
              IsVisible="{Binding IsModelLoading, Converter={StaticResource InvertBool}}">
            <SearchBar Placeholder="Search images by description..."
                       Text="{Binding SearchQuery}"
                       SearchCommand="{Binding SearchCommand}"
                       HorizontalOptions="Fill" />
            <Button Grid.Column="1"
                    Text="Search"
                    Command="{Binding SearchCommand}"
                    VerticalOptions="Center"
                    Margin="8,0,0,0" />
        </Grid>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Images}"
                        IsVisible="{Binding SearchResults.Count, Converter={StaticResource IsZero}}"
                        SelectionMode="None"
                        Margin="8">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="3"
                                 HorizontalItemSpacing="4"
                                 VerticalItemSpacing="4" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ImageEntity">
                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="Gray"
                            StrokeThickness="0.5"
                            Padding="2">
                        <Grid RowDefinitions="*,Auto">
                            <Image Source="{Binding FilePath}"
                                   Aspect="AspectFill"
                                   HeightRequest="120">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnImageTapped" />
                                </Image.GestureRecognizers>
                            </Image>
                            <Label Grid.Row="1"
                                   Text="{Binding FileName}"
                                   FontSize="10"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"
                                   Margin="4,2" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Padding="40">
                    <Label Text="No images yet"
                           FontSize="18"
                           HorizontalOptions="Center" />
                    <Label Text="Tap '+ Gallery' to add images"
                           FontSize="14"
                           HorizontalOptions="Center"
                           TextColor="Gray" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding SearchResults}"
                        IsVisible="{Binding SearchResults.Count, Converter={StaticResource NotIsZero}}"
                        SelectionMode="None"
                        Margin="8">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="3"
                                 HorizontalItemSpacing="4"
                                 VerticalItemSpacing="4" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SearchResult">
                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="Gold"
                            StrokeThickness="1"
                            Padding="2">
                        <Grid RowDefinitions="*,Auto,Auto,Auto,Auto">
                            <Image Source="{Binding Entity.FilePath}"
                                   Aspect="AspectFill"
                                   HeightRequest="120">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnImageTapped" />
                                </Image.GestureRecognizers>
                            </Image>
                            <Label Grid.Row="1"
                                   Text="{Binding Entity.FileName}"
                                   FontSize="10"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"
                                   Margin="4,2" />
                            <Label Grid.Row="2"
                                   Text="{Binding Score, StringFormat='Cos: {0:F2}'}"
                                   FontSize="9"
                                   TextColor="Gold"
                                   Margin="4,0,4,2" />
                            <Label Grid.Row="3"
                                   Text="{Binding DotProduct, StringFormat='Dot: {0:F2}'}"
                                   FontSize="9"
                                   TextColor="Orange"
                                   Margin="4,0,4,2" />
                            <Label Grid.Row="4"
                                   Text="{Binding LogitScore, StringFormat='Logit: {0:F2}'}"
                                   FontSize="9"
                                   TextColor="Cyan"
                                   Margin="4,0,4,2" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="3"
               Text="{Binding StatusMessage}"
               Padding="12,4"
               FontSize="12"
               TextColor="Gray" />

    </Grid>

</ContentPage>
